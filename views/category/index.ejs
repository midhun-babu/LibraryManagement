<%- include('../partials/header', { title: 'Categories' }) %>
<%- include('../partials/navbar') %>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Categories</h2>
        <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
            <!-- Fixed typo: /category/create -->
            <a href="/category/create" class="btn btn-success">Add New Category</a>
        <% } %>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Category Name</th>
                <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
                    <th class="text-end">Actions</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% categories.forEach(cat => { %>
                <tr>
                    <td class="align-middle"><%= cat.name %></td>
                    <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
                        <td class="text-end">
                            <a href="/category/<%= cat._id %>/update" class="btn btn-sm btn-warning">Edit</a>
                            <form action="/category/<%= cat._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this category?')">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    <% } %>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <% if (pagination && pagination.totalPages > 1) { %>
    <nav aria-label="Category pagination" class="mt-3">
      <ul class="pagination justify-content-center">
        <% const qsBaseCat = (p) => {
             let qs = `page=${p}&limit=${pagination.limit}`;
             return qs;
           };
        %>
        <% if (pagination.page > 1) { %>
          <li class="page-item">
            <a class="page-link" href="?<%= qsBaseCat(pagination.page - 1) %>">Previous</a>
          </li>
        <% } %>
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="?<%= qsBaseCat(i) %>"><%= i %></a>
          </li>
        <% } %>
        <% if (pagination.page < pagination.totalPages) { %>
          <li class="page-item">
            <a class="page-link" href="?<%= qsBaseCat(pagination.page + 1) %>">Next</a>
          </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
</div>

<%- include('../partials/footer') %>
