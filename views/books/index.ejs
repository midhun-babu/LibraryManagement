<%- include('../partials/header', { title: 'Books' }) %>
<%- include('../partials/navbar') %>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Books List</h2>
        <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
            <a href="/books/form" class="btn btn-success">Add New Book</a>
        <% } %>
    </div>

    <!-- Search and Filter Section -->
    <div class="card p-3 mb-4 shadow-sm bg-light">
        <form action="/books" method="GET" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="search" class="form-control" placeholder="Search by title or author..." value="<%= locals.search || '' %>">
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= locals.selectedCat == cat._id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-md-2">
                <a href="/books" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
                    <th>Actions</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% if (books.length > 0) { %>
                <% books.forEach(book => { %>
                    <tr>
                        <td><%= book.title %></td>
                        <td><%= book.author %></td>
                        <td><%= book.category?.name || 'Uncategorized' %></td>
                        <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
                            <td>
                                <a href="/books/<%= book._id %>/form" class="btn btn-sm btn-warning">Edit</a>
                                <form action="/books/<%= book._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure?')">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        <% } %>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="4" class="text-center">No books found matching your criteria.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
