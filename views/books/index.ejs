<%- include('../partials/header', { title: 'Books' }) %>
<%- include('../partials/navbar') %>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Books Library</h2>
        <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
            <a href="/books/form" class="btn btn-success shadow-sm">Add New Book</a>
        <% } %>
    </div>

    <!-- Filter Form -->
    <div class="card p-3 mb-4 shadow-sm bg-light border-0">
        <form action="/books" method="GET" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="search" class="form-control" placeholder="Search title or author..." value="<%= locals.search || '' %>">
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= locals.selectedCat == cat._id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
                <a href="/books" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>

    <!-- Books Table -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Category</th>
                    <th>Stock Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (books && books.length > 0) { %>
                    <% books.forEach(book => { %>
                        <tr class="align-middle">
                            <td class="fw-bold"><%= book.title %></td>
                            <td><%= book.author %></td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark">
                                    <%= book.category?.name || 'General' %>
                                </span>
                            </td>
                            <td>
                                <% const statusClass = book.availableCopies > 0 ? 'bg-success' : 'bg-danger'; %>
                                <span class="badge <%= statusClass %>">
                                    <%= book.availableCopies > 0 ? 'Available' : 'Out of Stock' %>
                                </span>
                                <small class="d-block text-muted mt-1">
                                    <%= book.availableCopies %> of <%= book.totalCopies %> left
                                </small>
                            </td>
                            <td class="text-end">
                                <div class="btn-group shadow-sm">
                                    <% if (locals.user && (user.role === 'admin' || user.role === 'librarian')) { %>
                                        <a href="/books/<%= book._id %>/form" class="btn btn-sm btn-outline-warning">Edit</a>
                                        
                                        <% if (book.availableCopies > 0) { %>
                                            <button type="button" class="btn btn-sm btn-outline-primary" 
                                                onclick="openIssueModal('<%= book._id %>', '<%= book.title %>')">
                                                Issue
                                            </button>
                                        <% } %>

                                        <form action="/books/<%= book._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this book?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    <% } else if (locals.user && user.role === 'user') { %>
                                        <form action="/bookRequests/<%= book._id %>/request" method="POST">
                                            <button type="submit" class="btn btn-sm btn-success" <%= book.availableCopies <= 0 ? 'disabled' : '' %>>
                                                <%= book.availableCopies > 0 ? 'Request' : 'Waitlist' %>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" class="text-center py-4 text-muted">No books found matching your criteria.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <% if (locals.pagination && pagination.totalPages > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% 
            const buildUrl = (p) => {
                let params = new URLSearchParams({ page: p, limit: pagination.limit });
                if (locals.search) params.append('search', search);
                if (locals.selectedCat) params.append('category', selectedCat);
                return '?' + params.toString();
            };
        %>
        <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= buildUrl(pagination.page - 1) %>">Previous</a>
        </li>
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="<%= buildUrl(i) %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= buildUrl(pagination.page + 1) %>">Next</a>
        </li>
      </ul>
    </nav>
    <% } %>
</div>

<!-- Issue Book Modal -->
<div class="modal fade" id="issueModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">Issue Book Transaction</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="issueForm" method="POST">
        <div class="modal-body">
          
          <!-- Book Title -->
          <div class="mb-3">
            <label class="form-label fw-bold">Book Title</label>
            <input type="text" id="modalBookTitle" class="form-control bg-light" readonly>
          </div>

          <!-- Issue Date -->
          <div class="mb-3">
            <label class="form-label fw-bold">Issue Date</label>
            <input type="date" id="modalIssueDate" name="issueDate" class="form-control">
          </div>

          <!-- Borrower Username/Email -->
          <div class="mb-3">
            <label class="form-label fw-bold">Borrower Username / Email</label>
            <input type="text" name="borrower" class="form-control" placeholder="Enter username or email..." required>
          </div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" onclick="return confirm('issue this book?')">Confirm Issue</button>
        </div>
      </form>
    </div>
  </div>
</div>


<script>
function openIssueModal(bookId, bookTitle) {
    const form = document.getElementById('issueForm');
    const titleInput = document.getElementById('modalBookTitle');
    const dateInput = document.getElementById('modalIssueDate');

   
    form.action = `books/${bookId}/issue`; 
    titleInput.value = bookTitle;
    const today = new Date().toISOString().split('T')[0]; 
    dateInput.value = today;

    
    const modal = new bootstrap.Modal(document.getElementById('issueModal'));
    modal.show();
}
</script>


<%- include('../partials/footer') %>



