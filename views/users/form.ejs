<%- include('../partials/header', { title: (locals.user ? 'Edit User' : 'Add New User') }) %>
<%- include('../partials/navbar') %>

<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3">
          <h4 class="mb-0"><%= locals.user ? 'Edit Existing User' : 'Register New User' %></h4>
        </div>
        <div class="card-body p-4">

          <form action="<%= locals.user ? '/users/' + user._id + '/update' : '/users' %>" method="POST">

            <div class="row">
              <!-- Name -->
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Full Name</label>
                <input type="text" name="name" class="form-control" maxlength="100"
                       value="<%= locals.user ? user.name : '' %>" placeholder="e.g. John Doe" required>
              </div>

              <!-- Username -->
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Username</label>
                <input type="text" name="uname" class="form-control" maxlength="50"
                       value="<%= locals.user ? user.uname : '' %>" placeholder="e.g. johndoe" required>
              </div>

              <!-- Email -->
              <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Email Address</label>
                <input type="email" name="email" class="form-control"
                       value="<%= locals.user ? user.email : '' %>" placeholder="e.g. john@example.com" required>
              </div>

              <!-- Password (only for new users) -->
              <% if (!locals.user) { %>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Password</label>
                <input type="password" name="password" class="form-control" minlength="6" required>
                <small class="text-muted">Minimum 6 characters</small>
              </div>
              <% } %>

              <!-- Role -->
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Role</label>
                <select name="role" class="form-select" required>
                  <option value="user" <%= locals.user && user.role === 'user' ? 'selected' : '' %>>User</option>
                  <option value="librarian" <%= locals.user && user.role === 'librarian' ? 'selected' : '' %>>Librarian</option>
                  <% if (locals.user && locals.user.role === 'admin') { %>
                  <option value="admin" <%= locals.user && user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                  <% } %>
                </select>
              </div>

            </div>

            <div class="d-flex justify-content-between mt-4">
              <a href="/users" class="btn btn-secondary">Cancel</a>
              <button type="submit" class="btn btn-primary">
                <%= locals.user ? 'Update User' : 'Create User' %>
              </button>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>