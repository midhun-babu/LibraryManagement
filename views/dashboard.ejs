
  <%- include("partials/header") %>

  <div class="container mt-4">
    <h2 class="mb-4">Library Dashboard</h2>

    <!-- Books -->
    <h3>Books</h3>
    <table class="table table-striped">
      <thead>
        <tr><th>Title</th><th>Author</th><th>Category</th></tr>
      </thead>
      <tbody>
        <% books.forEach(book => { %>
          <tr>
            <td><%= book.title %></td>
            <td><%= book.author %></td>
            <td><%= book.category %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Categories -->
    <h3>Categories</h3>
    <ul class="list-group mb-4">
      <% categories.forEach(cat => { %>
        <li class="list-group-item"><%= cat.name %></li>
      <% }) %>
    </ul>

    <!-- Users -->
    <h3>Users</h3>
    <table class="table table-bordered">
      <thead>
        <tr><th>Name</th><th>Email</th></tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%- include("partials/footer") %>