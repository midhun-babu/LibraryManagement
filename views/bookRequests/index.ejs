<%- include('../partials/header', { title: 'Book Requests Management' }) %>
<%- include('../partials/navbar') %>

<div class="container mt-5">
  <h2>Book Requests Management</h2>

  <table class="table table-hover shadow-sm">
    <thead class="table-dark">
      <tr>
        <th>User</th>
        <th>Book Title</th>
        <th>Author</th>
        <th>Requested Date</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% requests.forEach(request => { %>
        <tr>
          <td><%= request.requestedBy ? request.requestedBy.name : 'Unknown User' %> (<%= request.requestedBy ? request.requestedBy.email : 'N/A' %>)</td>
          <td><%= request.bookId ? request.bookId.title : 'Unknown Book' %></td>
          <td><%= request.bookId ? request.bookId.author : 'N/A' %></td>
          <td><%= new Date(request.requestedDate).toLocaleDateString() %></td>
          <td>
            <span class="badge <%= request.status === 'pending' ? 'bg-warning' : (request.status === 'approved' ? 'bg-info' : (request.status === 'issued' ? 'bg-success' : 'bg-danger')) %>">
              <%= request.status %>
            </span>
          </td>
          <td>
            <% if (request.status === 'pending') { %>
              <form action="/bookRequests/approve/<%= request._id %>" method="POST" class="d-inline">
                <button type="submit" class="btn btn-success btn-sm">Approve</button>
              </form>
              <form action="/bookRequests/reject/<%= request._id %>" method="POST" class="d-inline">
                <button type="submit" class="btn btn-danger btn-sm">Reject</button>
              </form>
            <% } else if (request.status === 'approved') { %>
              <form action="/bookRequests/issue/<%= request._id %>" method="POST" class="d-inline">
                <button type="submit" class="btn btn-primary btn-sm">Issue Book</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (requests.length === 0) { %>
        <tr><td colspan="6" class="text-center">No book requests found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>