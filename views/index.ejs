

<%- include('partials/header', { title: 'My Page' }) %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<header class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 fw-bold">Library Dashboard</h1>
        <p class="lead opacity-75">Manage your inventory, users, and categories in real-time.</p>
    </div>
</header>

<!-- Statistics / Dashboard Cards -->
<main class="container mb-5">
    <div class="row g-4 justify-content-center">
        
        <!-- Books Card -->
        <div class="col-md-4">
            <div class="card shadow-lg p-4">
                <div class="card-body text-center">
                    <div class="stat-number mb-2"><%= bookCount %></div>
                    <h5 class="card-title text-uppercase text-muted small fw-bold">Total Books</h5>
                    <p class="text-secondary">Books currently in the system.</p>
                    <a href="/books.ejs" class="btn btn-outline-primary w-100 mt-3 rounded-pill">Manage Books</a>
                </div>
            </div>
        </div>

        <!-- Categories Card -->
        <div class="col-md-4">
            <div class="card shadow-lg p-4">
                <div class="card-body text-center">
                    <div class="stat-number mb-2"><%= categoryCount %></div>
                    <h5 class="card-title text-uppercase text-muted small fw-bold">Categories</h5>
                    <p class="text-secondary">Genres and classifications.</p>
                    <a href="/categories" class="btn btn-outline-primary w-100 mt-3 rounded-pill">View Genres</a>
                </div>
            </div>
        </div>

        <!-- Members Card -->
        <div class="col-md-4">
            <div class="card shadow-lg p-4">
                <div class="card-body text-center">
                    <div class="stat-number mb-2"><%= userCount %></div>
                    <h5 class="card-title text-uppercase text-muted small fw-bold">Members</h5>
                    <p class="text-secondary">Registered library users.</p>
                    <a href="/users" class="btn btn-outline-primary w-100 mt-3 rounded-pill">User List</a>
                </div>
            </div>
        </div>

    </div>
</main>
<%- include('partials/footer') %>



